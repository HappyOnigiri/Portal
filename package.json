{
	"name": "workspace",
	"type": "module",
	"version": "1.5.1",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "node --experimental-strip-types scripts/run-dev.ts",
		"dev:raw": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "biome check . --error-on-warnings",
		"check:fix": "biome check . --write",
		"lint": "biome check .",
		"format": "biome format --write . && npm run format:astro",
		"format:astro": "prettier --write \"**/*.astro\"",
		"format:astro:check": "prettier --check \"**/*.astro\"",
		"typecheck": "astro sync && tsc --noEmit",
		"check:ts-rules": "python3 scripts/check_ts_rules.py",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"collect-metrics": "node --experimental-strip-types scripts/collect-metrics.ts"
	},
	"dependencies": {
		"@astrojs/react": "^5.0.2",
		"@astrojs/sitemap": "^3.7.2",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/noto-sans-jp": "^5.2.9",
		"@fontsource/noto-serif-jp": "^5.2.8",
		"@fontsource/orbitron": "^5.2.8",
		"@tailwindcss/vite": "^4.2.2",
		"@vercel/analytics": "^2.0.1",
		"astro": "^6.1.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.2",
		"happy-dom": "^20.8.9",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"typescript": "^6.0.2",
		"vitest": "^4.0.18"
	}
}
