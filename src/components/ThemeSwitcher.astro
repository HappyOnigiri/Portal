---
export interface Props {
	theme?: "cyber" | "minimal" | "pop" | "glass" | "terminal" | "brutal";
}
const { theme = "cyber" } = Astro.props;

let nextUrl = "/";
let label = "";

if (theme === "cyber") {
	nextUrl = "/minimal";
	label = "THEME: CYBER";
} else if (theme === "minimal") {
	nextUrl = "/pop";
	label = "Theme: Minimal";
} else if (theme === "pop") {
	nextUrl = "/glass";
	label = "THEME: POP";
} else if (theme === "glass") {
	nextUrl = "/terminal";
	label = "Theme: Glass";
} else if (theme === "terminal") {
	nextUrl = "/brutal";
	label = "THEME: TERMINAL";
} else if (theme === "brutal") {
	nextUrl = "/";
	label = "THEME: BRUTAL";
}
---

<div class="flex">
	<a
		href={nextUrl}
		class="text-[10px] opacity-70 hover:opacity-100 transition-opacity flex items-center gap-1 cursor-pointer"
		style="color: var(--text-main); text-decoration: none; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Courier, monospace !important;"
		title={`Next Theme: ${label.replace("THEME: ", "").replace("Theme: ", "").toLowerCase()}`}
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="14"
			height="14"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
		</svg>
		<span>theme</span>
	</a>
</div>
