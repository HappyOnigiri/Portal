---
import BrutalWidget from "./themes/brutal/ProjectCard.astro";
import CyberWidget from "./themes/cyber/ProjectCard.astro";
import NagomiWidget from "./themes/nagomi/ProjectCard.astro";
import PopWidget from "./themes/pop/ProjectCard.astro";

export interface ProjectData {
	id: string;
	title: string;
	title_en?: string;
	description: string;
	description_en?: string;
	image?: string;
	image_fit?: "cover" | "contain";
	image_contain_bg?: string;
	url?: string;
	category?: string;
	category_color?: string;
}

interface Props {
	project: ProjectData;
	theme?: "cyber" | "pop" | "brutal" | "nagomi";
	index?: number;
}

const { project, theme = "cyber", index = 0 } = Astro.props as Props;
---

{theme === "cyber" && <CyberWidget project={project} />}
{theme === "pop" && <PopWidget project={project} />}
{theme === "brutal" && <BrutalWidget project={project} index={index} />}
{theme === "nagomi" && <NagomiWidget project={project} />}
