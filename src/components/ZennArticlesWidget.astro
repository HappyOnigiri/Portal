---
import type { CollectionEntry } from "astro:content";

interface Props {
	articles: CollectionEntry<"zennArticles">[];
}

const { articles } = Astro.props;

const formatDate = (iso: string) =>
	new Date(iso).toLocaleDateString("ja-JP", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		timeZone: "Asia/Tokyo",
	});
---

<div
	class="w-full max-w-[1160px] mx-auto bg-[#141623]/80 border border-[#2dd4bf]/30 rounded-xl shadow-[0_0_15px_rgba(0,240,255,0.1)] overflow-hidden backdrop-blur-sm text-sm sm:text-base font-mono"
>
	<div class="px-6 pt-5 pb-1">
		<h2 class="section-heading">Zenn Articles</h2>
	</div>

	<div class="p-6 overflow-x-auto">
		<table class="w-full border-collapse">
			<tbody class="text-[#e2e8f0]">
				{
					articles.map((article) => (
						<tr class="zenn-article-row border-b border-[#2dd4bf]/10 hover:bg-[#00f0ff]/5 transition-colors group">
							<td class="py-4 px-2 text-2xl w-10 shrink-0">
								{article.data.emoji}
							</td>
							<td class="py-4 px-2 flex-1">
								<a
									href={`https://zenn.dev/happy_onigiri/articles/${article.data.slug}`}
									class="zenn-article-link"
									target="_blank"
									rel="noopener noreferrer"
								>
									{article.data.title}
								</a>
							</td>
							<td class="py-4 px-2 text-[#94a3b8] text-xs whitespace-nowrap text-right">
								{formatDate(article.data.published_at)}
							</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>

	<div class="px-6 pb-5 text-right">
		<a
			href="https://zenn.dev/happy_onigiri"
			class="zenn-all-link"
			target="_blank"
			rel="noopener noreferrer"
		>
			<span data-i18n="zenn.viewAll">すべての記事を見る →</span>
		</a>
	</div>
</div>
