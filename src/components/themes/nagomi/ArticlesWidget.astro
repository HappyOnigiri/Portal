---
import type { CollectionEntry } from "astro:content";

interface Props {
	articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;

const formatDate = (iso: string) =>
	new Date(iso).toLocaleDateString("ja-JP", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		timeZone: "Asia/Tokyo",
	});
---

<div class="w-full max-w-[1100px] mx-auto text-sm sm:text-base">
	<div
		class="flex flex-col w-full bg-[rgba(255,255,255,0.9)] border border-[#D4C5B0] rounded-lg overflow-hidden"
		style="box-shadow: 0 2px 8px rgba(0,0,0,0.06);"
	>
		<div class="px-6 pt-5 pb-1">
			<h2
				class="text-lg font-bold tracking-wide m-0 mb-4 border-b border-[#D4C5B0] pb-3"
				style="font-family: 'Noto Serif JP', serif; color: #2B2B2B; letter-spacing: 0.2em;"
				data-lang-ja="記事"
				data-lang-en="Articles"
			>
				記事
			</h2>
		</div>

		<div class="px-6 pb-2">
			<div class="flex flex-col">
				{
					articles.map((article) => (
						<a
							href={article.data.url}
							data-href-ja={article.data.url}
							data-href-en={
								article.data.platform === "zenn"
									? `${article.data.url}?locale=en`
									: article.data.url
							}
							class="flex items-center gap-4 py-4 px-2 border-b border-[#D4C5B0] transition-colors group"
							style="text-decoration: none;"
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="text-2xl w-10 shrink-0">
								{article.data.emoji || "📝"}
							</div>
							<div
								class="flex-1 transition-colors group-hover:text-[#9E2A2B]"
								style="color: #2B2B2B;"
							>
								<span
									data-lang-ja={article.data.title}
									data-lang-en={article.data.title_en || article.data.title}
								>
									{article.data.title}
								</span>
							</div>
							<img
								src={`/images/logos/logo_${article.data.platform}.svg`}
								alt={article.data.platform}
								class="w-4 h-4 shrink-0 opacity-60"
							/>
							<div
								class="text-xs whitespace-nowrap text-right"
								style="color: #6B5E50;"
							>
								{formatDate(article.data.published_at)}
							</div>
						</a>
					))
				}
			</div>
		</div>

		<div class="px-6 pb-5 flex justify-end gap-4">
			<a
				href="https://zenn.dev/happy_onigiri"
				class="text-sm transition-colors hover:text-[#9E2A2B] inline-flex items-center gap-1"
				style="color: #6B5E50; text-decoration: none;"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img src="/images/logos/logo_zenn.svg" alt="Zenn" class="w-4 h-4" />
				<span data-i18n="articles.viewAllZenn">Zenn →</span>
			</a>
			<a
				href="https://note.com/happy_onigiri"
				class="text-sm transition-colors hover:text-[#9E2A2B] inline-flex items-center gap-1"
				style="color: #6B5E50; text-decoration: none;"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img src="/images/logos/logo_note.svg" alt="note" class="w-4 h-4" />
				<span data-i18n="articles.viewAllNote">note →</span>
			</a>
		</div>
	</div>
</div>
