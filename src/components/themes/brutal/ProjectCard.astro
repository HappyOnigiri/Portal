---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { ProjectData } from "../../ProjectCard.astro";

export interface Props {
	project: ProjectData;
	hrefMode?: "detail" | "external";
	index?: number;
}

const { project, hrefMode = "external", index = 0 } = Astro.props;
const detailHref = `/projects/${project.id}`;
const href = hrefMode === "detail" ? detailHref : (project.url ?? detailHref);

const imageFit = project.image_fit ?? "cover";
const containBgStyle =
	imageFit === "contain" && project.image_contain_bg
		? `background-color: ${project.image_contain_bg};`
		: undefined;

const thumbnails = import.meta.glob<{ default: ImageMetadata }>(
	"../../../assets/images/thumbnails/*.{jpg,jpeg,png,gif,webp,avif,svg}",
);

let resolvedImage: ImageMetadata | undefined;
if (project.image) {
	const filename = project.image.split("/").at(-1);
	const globKey = `../../../assets/images/thumbnails/${filename}`;
	const loader = thumbnails[globKey];
	if (loader) {
		resolvedImage = (await loader()).default;
	}
}

const colors = ["#eeff00", "#ff00ea", "#0051ff", "#00ff22", "#ff0000", "#fff"];
const bgColor = colors[index % colors.length];
const rotation = (index % 2 === 0 ? 1 : -1) * (Math.random() * 1.5 + 0.5);
---

<a
	href={href}
	class="brutal-card"
	style={`background-color: ${bgColor}; transform: rotate(${rotation}deg);`}
>
	{
		resolvedImage && (
			<div class="brutal-card-image" style={containBgStyle}>
				<Image
					src={resolvedImage}
					alt={`${project.title} のサムネイル`}
					data-lang-ja={`${project.title} のサムネイル`}
					data-lang-en={`${project.title_en || project.title} thumbnail`}
					loading="lazy"
					width={600}
					style={`object-fit: ${imageFit};`}
				/>
			</div>
		)
	}
	<div class="brutal-card-content">
		<h3
			class="brutal-card-title"
			data-lang-ja={project.title}
			data-lang-en={project.title_en || project.title}
		>
			{project.title}
		</h3>
		<p
			class="brutal-card-desc"
			data-lang-ja={project.description}
			data-lang-en={project.description_en || project.description}
		>
			{project.description}
		</p>
		{
			project.category && (
				<div class="brutal-tag" data-color={project.category_color}>
					{project.category}
				</div>
			)
		}
	</div>
</a>

<style>
	.brutal-card {
		display: block;
		border: 5px solid #000;
		box-shadow: 12px 12px 0 #000;
		text-decoration: none;
		color: #000;
		transition: all 0.1s steps(3);
		position: relative;
		width: calc(100% - 32px);
		margin: 0 auto;
		box-sizing: border-box;
	}

	.brutal-card:hover {
		transform: rotate(0deg) scale(1.02) translate(-5px, -5px) !important;
		box-shadow: 20px 20px 0 #000;
		z-index: 10;
		width: calc(100% - 32px);
	}

	.brutal-card:active {
		transform: translate(5px, 5px) !important;
		box-shadow: 0 0 0 #000;
		width: calc(100% - 32px);
	}

	.brutal-card-image {
		border-bottom: 5px solid #000;
		height: 200px;
		background: #fff;
		overflow: hidden;
	}

	.brutal-card-image :global(img) {
		width: 100%;
		height: 100%;
		filter: contrast(150%) saturate(120%) grayscale(20%);
	}

	.brutal-card-content {
		padding: 30px;
	}

	.brutal-card-title {
		font-family: var(--font-brutal);
		font-size: 2rem;
		margin: 0 0 15px 0;
		line-height: 1.1;
		word-break: break-word;
	}

	.brutal-card-desc {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0 0 20px 0;
		line-height: 1.4;
	}

	.brutal-tag {
		--tag-color: #000;
		display: inline-block;
		background: #fff;
		border: 2px solid #000;
		color: var(--tag-color);
		text-shadow:
			2px 2px 0 #000,
			-1px -1px 0 #000,
			1px -1px 0 #000,
			-1px 1px 0 #000;
		font-family: var(--font-brutal);
		padding: 5px 10px;
		font-size: 1.2rem;
	}

	.brutal-tag[data-color="cyan"] {
		--tag-color: #06b6d4;
	}
	.brutal-tag[data-color="emerald"] {
		--tag-color: #10b981;
	}
	.brutal-tag[data-color="amber"] {
		--tag-color: #f59e0b;
	}
	.brutal-tag[data-color="purple"] {
		--tag-color: #8b46f5;
	}
	.brutal-tag[data-color="blue"] {
		--tag-color: #3b82f6;
	}
	.brutal-tag[data-color="pink"] {
		--tag-color: #e879f9;
	}

	@media (max-width: 768px) {
		.brutal-card-title {
			font-size: 1.5rem;
		}
		.brutal-card-desc {
			font-size: 1rem;
		}
	}
</style>
