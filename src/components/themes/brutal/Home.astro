---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AuthorStatusWidget from "./AuthorStatusWidget.astro";
import ProjectCard from "./ProjectCard.astro";
import ZennArticlesWidget from "./ZennArticlesWidget.astro";

export interface Props {
	projects: CollectionEntry<"projects">["data"][];
	zennEntries: CollectionEntry<"zennArticles">[];
	jsonLd: Record<string, unknown>;
	metaDescriptionJa: string;
}
const { projects, zennEntries, jsonLd, metaDescriptionJa } = Astro.props;
const theme = "brutal";
---

<BaseLayout
	theme={theme}
	title="ONIGIRI PORTAL | BRUTAL"
	description={metaDescriptionJa}
	canonicalPath="/"
	jsonLd={jsonLd}
>
	<div class="brutal-root">
		<header class="brutal-header">
			<div class="brutal-marquee">
				<div class="marquee-content">
					PORTAL PORTAL PORTAL PORTAL PORTAL PORTAL PORTAL PORTAL PORTAL PORTAL
					PORTAL
				</div>
			</div>
			<div class="brutal-hero-box">
				<h1 class="brutal-title">HAPPY<br />ONIGIRI</h1>
				<div class="brutal-badge">WARNING: BRUTAL</div>
			</div>
		</header>

		<div class="brutal-grid">
			<main class="brutal-main">
				<section
					id="projects"
					aria-label="Projects"
					class="brutal-section project-section"
				>
					<h2 class="brutal-heading">PROJECTS.EXE</h2>
					<div class="brutal-projects">
						{
							projects.map((project, index) => (
								<ProjectCard project={project} theme={theme} index={index} />
							))
						}
					</div>
				</section>
			</main>

			<aside class="brutal-sidebar">
				<section
					id="status"
					aria-label="Status"
					class="brutal-section status-section"
				>
					<h2 class="brutal-heading">STATUS_</h2>
					<AuthorStatusWidget theme={theme} />
				</section>

				{
					zennEntries.length > 0 && (
						<section
							id="articles"
							aria-label="Articles"
							class="brutal-section articles-section"
						>
							<h2 class="brutal-heading">LOG.TXT</h2>
							<ZennArticlesWidget articles={zennEntries} theme={theme} />
						</section>
					)
				}
			</aside>
		</div>
	</div>
</BaseLayout>

<style is:global>
	[data-theme="brutal"] {
		--bg-color: #f4f4f0;
		--text-main: #000;
		--brutal-yellow: #eeff00;
		--brutal-pink: #ff00ea;
		--brutal-blue: #0051ff;
		--brutal-green: #00ff22;
		--brutal-red: #ff0000;
		--font-brutal: "Impact", "Arial Black", sans-serif;
	}

	[data-theme="brutal"] body {
		background-color: var(--bg-color);
		background-image: radial-gradient(#000 1px, transparent 1px);
		background-size: 20px 20px;
		color: var(--text-main);
		font-family: "Helvetica Neue", Arial, sans-serif;
	}

	[data-theme="brutal"] .cyber-container {
		max-width: 1400px;
		padding: 0;
	}

	[data-theme="brutal"] .cyber-footer {
		background: #000;
		color: #fff;
		border-top: 5px solid #000;
		padding: 40px;
		margin-top: 100px;
	}

	.brutal-root {
		overflow: hidden;
		padding-bottom: 50px;
	}

	.brutal-header {
		margin-bottom: 60px;
		position: relative;
	}

	.brutal-marquee {
		background: var(--brutal-yellow);
		border-top: 4px solid #000;
		border-bottom: 4px solid #000;
		padding: 10px 0;
		overflow: hidden;
		white-space: nowrap;
		transform: rotate(-2deg);
		margin: 20px -20px;
		box-shadow: 0 10px 0 rgba(0, 0, 0, 1);
	}

	.marquee-content {
		font-family: var(--font-brutal);
		font-size: 3rem;
		text-transform: uppercase;
		display: inline-block;
		animation: scroll 15s linear infinite;
	}

	@keyframes scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	.brutal-hero-box {
		padding: 60px 20px;
		border: 8px solid #000;
		background: #fff;
		box-shadow: 20px 20px 0 #000;
		max-width: 800px;
		margin: 40px auto;
		position: relative;
		transform: rotate(1deg);
	}

	.brutal-title {
		font-family: var(--font-brutal);
		font-size: 8rem;
		line-height: 0.9;
		margin: 0;
		letter-spacing: -5px;
		text-transform: uppercase;
		-webkit-text-stroke: 3px #000;
		color: var(--brutal-pink);
		text-shadow: 8px 8px 0 #000;
	}

	.brutal-badge {
		position: absolute;
		top: -20px;
		right: -20px;
		background: var(--brutal-red);
		color: #fff;
		font-family: var(--font-brutal);
		font-size: 1.5rem;
		padding: 10px 20px;
		border: 4px solid #000;
		transform: rotate(15deg);
		box-shadow: 5px 5px 0 #000;
	}

	.brutal-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 60px;
		padding: 0 40px;
	}

	.brutal-heading {
		font-family: var(--font-brutal);
		font-size: 3rem;
		text-transform: uppercase;
		background: #000;
		color: #fff;
		display: inline-block;
		padding: 10px 20px;
		margin-bottom: 40px;
		transform: skewX(-10deg);
		box-shadow: 10px 10px 0 var(--brutal-blue);
	}

	.brutal-projects {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 40px;
	}

	.brutal-sidebar {
		display: flex;
		flex-direction: column;
		gap: 80px;
	}

	@media (max-width: 1024px) {
		.brutal-grid {
			grid-template-columns: 1fr;
		}
		.brutal-title {
			font-size: 5rem;
		}
	}
</style>
