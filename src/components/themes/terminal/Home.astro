---
import type { CollectionEntry } from "astro:content";
import packageJson from "../../../../package.json";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticlesWidget from "./ArticlesWidget.astro";
import AuthorStatusWidget from "./AuthorStatusWidget.astro";
import ProjectCard from "./ProjectCard.astro";

export interface Props {
	projects: CollectionEntry<"projects">["data"][];
	articleEntries: CollectionEntry<"articles">[];
	jsonLd: Record<string, unknown>;
	metaDescriptionJa: string;
}
const { projects, articleEntries, jsonLd, metaDescriptionJa } = Astro.props;
const theme = "terminal";
---

<BaseLayout
	theme={theme}
	title="ONIGIRI PORTAL | ターミナル"
	description={metaDescriptionJa}
	canonicalPath="/"
	jsonLd={jsonLd}
>
	<div class="terminal-container">
		<header class="terminal-header">
			<div class="terminal-ascii-wrap">
				<pre
					class="terminal-ascii">
   ____        _       _      _
  / __ \____  (_)___ _(_)____(_)
 / / / / __ \/ / __ `/ / ___/ /
/ /_/ / / / / / /_/ / / /  / /
\____/_/ /_/_/\__, /_/_/  /_/
             /____/
				</pre>
				<pre
					class="terminal-ascii">
    ____             __        __
   / __ \____  _____/ /_____ _/ /
  / /_/ / __ \/ ___/ __/ __ `/ /
 / ____/ /_/ / /  / /_/ /_/ / /
/_/    \____/_/   \__/\__,_/_/

				</pre>
			</div>
			<div class="terminal-version">PORTAL v{packageJson.version}</div>
			<br />
		</header>

		<main class="terminal-main">
			<div class="command-block">
				<div class="prompt">
					<span class="user">root@portal</span>:<span class="dir">~</span>$
					fastfetch
				</div>
				<div class="output">
					<AuthorStatusWidget theme={theme} />
				</div>
			</div>

			<div class="command-block">
				<div class="prompt">
					<span class="user">root@portal</span>:<span class="dir"
						>~/projects</span
					>$ ls -1
				</div>
				<div class="output terminal-ls">
					{
						projects.map((project) => (
							<ProjectCard project={project} theme={theme} />
						))
					}
				</div>
			</div>

			{
				articleEntries.length > 0 && (
					<div class="command-block">
						<div class="prompt">
							<span class="user">root@portal</span>:
							<span class="dir">~/articles</span>$ cat latest.txt
						</div>
						<div class="output">
							<ArticlesWidget articles={articleEntries} theme={theme} />
						</div>
					</div>
				)
			}

			<div class="command-block">
				<div class="prompt">
					<span class="user">root@portal</span>:<span class="dir">~</span>$ <span
						class="cursor">_</span
					>
				</div>
			</div>
		</main>
	</div>
</BaseLayout>

<style is:global>
	[data-theme="terminal"] {
		--bg-color: #000000;
		--bg-image: none;
		--text-main: #f2f2f2;
		--text-muted: #888888;
		--accent-main: #ffffff;
		--terminal-font:
			ui-monospace, "SF Mono", "Menlo", "Monaco", "Consolas", monospace;

		/* Standard UI vars mapped to Terminal */
		--panel-bg: #000000;
		--card-border: 1px solid #4d4d4d;
		--card-shadow: none;
	}

	[data-theme="terminal"] body {
		background-color: var(--bg-color);
		color: var(--text-main);
		font-family: var(--terminal-font);
		padding: 20px;
		margin: 0;
	}

	[data-theme="terminal"] ::selection {
		background: #4d4d4d;
		color: #ffffff;
	}

	.terminal-container {
		max-width: 900px;
		margin: 0 auto;
		width: 100%;
		line-height: 1.5;
	}

	.terminal-ascii-wrap {
		display: flex;
		gap: 0;
		margin: 0 0 5px 0;
	}

	.terminal-ascii {
		font-family: var(--terminal-font);
		white-space: pre;
		margin: 0;
		font-size: 14px;
		line-height: 1.2;
		color: var(--text-main);
	}

	.terminal-version {
		font-family: var(--terminal-font);
		font-size: 14px;
		color: var(--text-main);
		margin: 0 0 20px 0;
		white-space: pre;
	}

	.terminal-header p {
		margin: 0;
		font-size: 14px;
	}

	.command-block {
		margin-bottom: 30px;
	}

	.prompt {
		font-weight: bold;
		margin-bottom: 15px;
		font-size: 14px;
	}

	.prompt .user {
		color: var(--text-main);
	}

	.prompt .dir {
		color: #66b3ff;
	}

	.output {
		padding-left: 0;
		margin-bottom: 20px;
		font-size: 14px;
	}

	.ls-header {
		margin-bottom: 10px;
	}

	.cursor {
		animation: blink 1s step-end infinite;
		display: inline-block;
		width: 10px;
		background: #f2f2f2;
		color: transparent;
	}

	@keyframes blink {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0;
		}
	}

	/* Prevent normal portal-container styles from messing up terminal */
	[data-theme="terminal"] .portal-container {
		padding: 0;
		max-width: none;
	}
	[data-theme="terminal"] .floating-ui-pill {
		/* Keep visible for ThemeSwitcher */
	}
	[data-theme="terminal"] .portal-footer {
		display: none;
	}

	@media (max-width: 768px) {
		[data-theme="terminal"] body {
			padding: 10px;
		}
		.terminal-ascii-wrap {
			flex-direction: column;
		}
		.terminal-ascii {
			font-size: 14px;
			line-height: 1.2;
		}
		.command-block {
			margin-bottom: 20px;
		}
		.prompt {
			font-size: 12px;
			word-break: break-all;
		}
		.output {
			font-size: 12px;
		}
	}
</style>
