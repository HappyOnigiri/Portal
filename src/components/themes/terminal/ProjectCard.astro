---
import type { Project } from "../../../utils/project";

export interface Props {
	project: Project;
	theme: string;
}

const { project } = Astro.props;
---

<div class="terminal-pkg-row">
	<div class="pkg-header">
		{
			project.url ? (
				<a
					class="pkg-name"
					href={project.url}
					target="_blank"
					rel="noopener noreferrer"
				>
					{project.title}
				</a>
			) : (
				<span class="pkg-name">{project.title}</span>
			)
		}
		{
			project.category && (
				<span class="pkg-category" data-color={project.category_color}>
					[{project.category}]
				</span>
			)
		}
	</div>
	<div
		class="pkg-desc"
		data-lang-ja={project.description}
		data-lang-en={project.description_en || project.description}
	>
		{project.description}
	</div>
</div>

<style>
	.terminal-pkg-row {
		margin-bottom: 12px;
		font-size: 14px;
	}

	.pkg-header {
		display: flex;
		align-items: baseline;
		gap: 6px;
	}

	.pkg-name {
		color: #66b3ff;
		text-decoration: none;
		font-weight: bold;
	}

	.pkg-name:hover {
		text-decoration: underline;
		background: #66b3ff;
		color: #000;
	}

	.pkg-category {
		font-weight: bold;
	}

	.pkg-category[data-color="cyan"] {
		color: #00f0ff;
	}
	.pkg-category[data-color="emerald"] {
		color: #10b981;
	}
	.pkg-category[data-color="amber"] {
		color: #f59e0b;
	}
	.pkg-category[data-color="purple"] {
		color: #8b46f5;
	}
	.pkg-category[data-color="blue"] {
		color: #3b82f6;
	}
	.pkg-category[data-color="pink"] {
		color: #e879f9;
	}

	.pkg-desc {
		color: #888888;
		padding-left: 2ch;
	}
</style>
