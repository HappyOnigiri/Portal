---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { ProjectData } from "../../ProjectCard.astro";

interface Props {
	project: ProjectData;
	hrefMode?: "detail" | "external";
}

const { project, hrefMode = "external" } = Astro.props as Props;
const detailHref = `/projects/${project.id}`;
const isDetailMode = hrefMode === "detail";
const imageFit = project.image_fit ?? "cover";
const containBgStyle =
	imageFit === "contain" && project.image_contain_bg
		? { "--image-contain-bg": project.image_contain_bg }
		: undefined;

const thumbnails = import.meta.glob<{ default: ImageMetadata }>(
	"../../../assets/images/thumbnails/*.{jpg,jpeg,png,gif,webp,avif,svg}",
);

let resolvedImage: ImageMetadata | undefined;
if (project.image) {
	const filename = project.image.split("/").at(-1);
	const globKey = `../../../assets/images/thumbnails/${filename}`;
	const loader = thumbnails[globKey];
	if (loader) {
		resolvedImage = (await loader()).default;
	}
}

const Wrapper = isDetailMode ? "a" : project.url ? "a" : "div";
const wrapperProps = isDetailMode
	? { href: detailHref, class: "card card--link" }
	: project.url
		? {
				href: project.url,
				class: "card card--link",
				target: "_blank",
				rel: "noopener noreferrer",
			}
		: { class: "card" };
---

<Wrapper {...wrapperProps}>
	<div class="flex flex-col w-full h-full p-6">
		{
			project.category && (
				<div class="mb-4">
					<span
						class="inline-block border-2 border-black px-3 py-1 font-black text-xs uppercase shadow-[4px_4px_0_#000] rotate-[-2deg]"
						style={`background-color: var(--category-bg, var(--accent-main)); color: #000;`}
					>
						{project.category}
					</span>
				</div>
			)
		}
		<h2
			class="font-black text-2xl tracking-wider leading-tight mb-4 text-black drop-shadow-[2px_2px_0_#fff]"
			style="font-family: var(--font-heading);"
			data-lang-ja={project.title}
			data-lang-en={project.title_en || project.title}
		>
			{project.title}
		</h2>
		{
			resolvedImage && (
				<div class="border-4 border-black mb-4 flex-shrink-0 bg-white shadow-[4px_4px_0_#000] overflow-hidden group-hover:-translate-y-1 transition-transform">
					<Image
						src={resolvedImage}
						alt={`${project.title} のサムネイル`}
						loading="lazy"
						widths={[400]}
						class="w-full h-40 object-cover"
						style={
							imageFit === "contain"
								? `object-fit: contain; background: ${project.image_contain_bg || "transparent"};`
								: ""
						}
					/>
				</div>
			)
		}
		<p
			class="font-bold text-sm leading-relaxed text-black"
			style="font-family: var(--font-body);"
			data-lang-ja={project.description}
			data-lang-en={project.description_en || project.description}
		>
			{project.description}
		</p>
	</div>
</Wrapper>
