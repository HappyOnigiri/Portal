---
import { Image } from "astro:assets";
import avatarImage from "../../../assets/images/avatar.jpg";
import statusData from "../../../data/author-status.json";

// 数値のフォーマット
const formatNumber = (num: number) =>
	new Intl.NumberFormat("ja-JP").format(num);
---

<div class="w-full max-w-[1160px] mx-auto text-sm sm:text-base">
	<div class="flex flex-col w-full" style="font-family: var(--font-body);">
		<div
			class="flex items-center gap-4 sm:gap-6 bg-white border-4 border-black p-4 sm:p-6 shadow-[8px_8px_0_#000] mb-12 transform -rotate-1"
		>
			<Image
				src={avatarImage}
				alt="Avatar"
				class="w-24 h-24 sm:w-32 sm:h-32 rounded-none border-4 border-black shadow-[4px_4px_0_#000] rotate-[-3deg]"
				loading="eager"
			/>
			<div class="flex flex-col justify-center">
				<h2
					class="font-black text-3xl sm:text-5xl tracking-widest text-black drop-shadow-[2px_2px_0_#fff]"
					style="font-family: var(--font-heading);"
				>
					HappyOnigiri
				</h2>
				<p
					class="font-bold text-base sm:text-lg border-2 border-black inline-block px-3 py-1 bg-[var(--accent-main)] shadow-[2px_2px_0_#000] mt-2 self-start transform rotate-1"
				>
					Driven by ideas.
				</p>
			</div>
		</div>

		<div
			class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 pt-4"
		>
			{/* Code Delta Note */}
			<div
				class="relative border-4 border-black bg-[#ff6b6b] p-6 shadow-[8px_8px_0_#000] transform rotate-2 hover:rotate-0 hover:-translate-y-2 transition-all duration-300 h-full min-h-[16rem] flex flex-col justify-start"
			>
				<span
					class="text-black font-black text-2xl border-b-4 border-black pb-2 leading-tight"
					style="font-family: var(--font-heading);">Code Delta</span
				>
				<span
					class="text-white text-[2.5rem] lg:text-[1.8rem] xl:text-[2.2rem] font-black mt-4 tracking-tighter leading-none"
					>{formatNumber(statusData.addedLines + statusData.deletedLines)}</span
				>
			</div>

			{/* Commits Note */}
			<div
				class="relative border-4 border-black bg-[var(--accent-main)] p-6 shadow-[8px_8px_0_#000] transform -rotate-2 hover:rotate-0 hover:-translate-y-2 transition-all duration-300 h-full min-h-[16rem] flex flex-col justify-start"
			>
				<span
					class="text-black font-black text-2xl border-b-4 border-black pb-2 leading-tight"
					style="font-family: var(--font-heading);">Commits</span
				>
				<span
					class="text-white text-[2.5rem] lg:text-[1.8rem] xl:text-[2.2rem] font-black mt-4 tracking-tighter leading-none"
					>{formatNumber(statusData.commits)}</span
				>
			</div>

			{/* PRs Merged Note */}
			<div
				class="relative border-4 border-black bg-[#10b981] p-6 shadow-[8px_8px_0_#000] transform rotate-3 hover:rotate-0 hover:-translate-y-2 transition-all duration-300 h-full min-h-[16rem] flex flex-col justify-start"
			>
				<span
					class="text-black font-black text-2xl border-b-4 border-black pb-2 leading-tight"
					style="font-family: var(--font-heading);">PRs Merged</span
				>
				<span
					class="text-black text-[2.5rem] lg:text-[1.8rem] xl:text-[2.2rem] font-black mt-4 tracking-tighter leading-none"
					>{formatNumber(statusData.mergedPRs)}</span
				>
			</div>

			{/* Lang Split Note */}
			<div
				class="relative border-4 border-black bg-[#fef08a] p-6 shadow-[8px_8px_0_#000] transform -rotate-1 hover:rotate-0 hover:-translate-y-2 transition-all duration-300 h-full min-h-[16rem] flex flex-col"
			>
				<span
					class="text-black font-black text-2xl border-b-4 border-black pb-2 mb-4 leading-tight shrink-0"
					style="font-family: var(--font-heading);">Lang Split</span
				>

				<div class="flex flex-wrap items-start gap-2 mt-auto">
					{
						statusData.languages.map((lang) => (
							<span class="text-xs font-black bg-white border-2 border-black px-2 py-1 shadow-[2px_2px_0_#000]">
								{lang.label} {lang.value}%
							</span>
						))
					}
				</div>
			</div>
		</div>
	</div>
</div>
