---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { Project } from "../../../utils/project";
import { translations } from "../../../utils/translations";

export interface Props {
	project: Project;
	theme: string;
}

const { project } = Astro.props;

const thumbnails = import.meta.glob<{ default: ImageMetadata }>(
	"../../../assets/images/thumbnails/*.{jpg,jpeg,png,gif,webp,avif,svg}",
);

let resolvedImage: ImageMetadata | undefined;
if (project.image) {
	const filename = project.image.split("/").at(-1);
	const globKey = `../../../assets/images/thumbnails/${filename}`;
	const loader = thumbnails[globKey];
	if (loader) {
		resolvedImage = (await loader()).default;
	}
}

// Randomly generate height for masonry effect if no image
const minHeight = resolvedImage
	? "auto"
	: `${Math.floor(Math.random() * 100) + 150}px`;
---

<a
	href={`/projects/${project.id}`}
	class="glass-card glass-project-card"
	style={`min-height: ${minHeight}`}
>
	{
		resolvedImage && (
			<div class="glass-project-image">
				<Image
					src={resolvedImage}
					alt={`${project.title} logo`}
					loading="lazy"
					width={600}
				/>
			</div>
		)
	}
	<div class="glass-project-content">
		<h3 class="glass-project-title">{project.title}</h3>
		{
			project.category && (
				<span
					class="glass-project-category"
					data-color={project.category_color}
				>
					{project.category}
				</span>
			)
		}
		<p class="glass-project-desc">{project.description}</p>
	</div>
</a>

<style>
	.glass-project-card {
		display: flex;
		flex-direction: column;
		padding: 0;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
	}

	.glass-project-image {
		width: 100%;
		height: 200px;
		overflow: hidden;
	}

	.glass-project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.glass-project-card:hover .glass-project-image img {
		transform: scale(1.05);
	}

	.glass-project-content {
		padding: 24px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.glass-project-title {
		font-family: "Outfit", sans-serif;
		font-size: 1.4rem;
		font-weight: 700;
		margin: 0;
		color: #1e293b;
	}

	.glass-project-category {
		align-self: flex-start;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 4px 12px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.8);
		color: #3b82f6; /* default color, can override based on data-color */
	}

	.glass-project-category[data-color="emerald"] {
		color: #10b981;
	}
	.glass-project-category[data-color="amber"] {
		color: #f59e0b;
	}
	.glass-project-category[data-color="purple"] {
		color: #8b5cf6;
	}
	.glass-project-category[data-color="pink"] {
		color: #ec4899;
	}

	.glass-project-desc {
		margin: 0;
		font-size: 0.95rem;
		color: #64748b;
		line-height: 1.5;
	}
</style>
