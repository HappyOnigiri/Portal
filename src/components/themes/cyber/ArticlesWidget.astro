---
import type { CollectionEntry } from "astro:content";

interface Props {
	articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;

const formatDate = (iso: string) =>
	new Date(iso).toLocaleDateString("ja-JP", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		timeZone: "Asia/Tokyo",
	});
---

<div class="w-full max-w-[1160px] mx-auto text-sm sm:text-base font-mono">
	<div
		class="flex flex-col w-full bg-[color:var(--panel-bg)] border border-[color:var(--panel-border)] rounded-xl shadow-[var(--card-shadow)] overflow-hidden backdrop-blur-sm"
	>
		<div class="px-6 pt-5 pb-1">
			<h2 class="section-heading">Articles</h2>
		</div>

		<div class="p-6">
			<div class="flex flex-col">
				{
					articles.map((article) => (
						<a
							href={article.data.url}
							data-href-ja={article.data.url}
							data-href-en={
								article.data.platform === "zenn"
									? `${article.data.url}?locale=en`
									: article.data.url
							}
							class="flex items-center gap-4 py-4 px-2 border-b border-[color:var(--panel-border)] hover:bg-[color:var(--panel-border)] transition-colors group"
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="text-2xl w-10 shrink-0">
								{article.data.emoji || "📝"}
							</div>
							<div class="flex-1 text-[color:var(--text-main)] group-hover:text-[color:var(--accent-main)] transition-colors">
								<span
									data-lang-ja={article.data.title}
									data-lang-en={article.data.title_en || article.data.title}
								>
									{article.data.title}
								</span>
							</div>
							<img
								src={`/images/logos/logo_${article.data.platform}.svg`}
								alt={article.data.platform}
								class="w-4 h-4 shrink-0 opacity-60"
							/>
							<div class="text-[color:var(--text-muted)] text-xs whitespace-nowrap text-right">
								{formatDate(article.data.published_at)}
							</div>
						</a>
					))
				}
			</div>
		</div>

		<div class="px-6 pb-5 flex justify-end gap-4">
			<a
				href="https://zenn.dev/happy_onigiri"
				class="article-all-link inline-flex items-center gap-1"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img src="/images/logos/logo_zenn.svg" alt="Zenn" class="w-4 h-4" />
				<span data-i18n="articles.viewAllZenn">Zenn →</span>
			</a>
			<a
				href="https://note.com/happy_onigiri"
				class="article-all-link inline-flex items-center gap-1"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img src="/images/logos/logo_note.svg" alt="note" class="w-4 h-4" />
				<span data-i18n="articles.viewAllNote">note →</span>
			</a>
		</div>
	</div>
</div>
