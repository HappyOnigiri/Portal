---
import { Image } from "astro:assets";
import avatarImage from "../assets/images/avatar.jpg";
import statusData from "../data/author-status.json";
import { translations } from "../utils/translations";

// 数値のフォーマット
const formatNumber = (num: number) =>
	new Intl.NumberFormat("ja-JP").format(num);

const lastSync = statusData.lastUpdated
	? new Date(statusData.lastUpdated).toLocaleString("ja-JP", {
			year: "numeric",
			month: "2-digit",
			day: "2-digit",
			hour: "2-digit",
			minute: "2-digit",
			timeZone: "Asia/Tokyo",
			timeZoneName: "short",
		})
	: "---";
---

<div
	class="w-full max-w-[1160px] mx-auto bg-[#141623]/80 border border-[#2dd4bf]/30 rounded-xl shadow-[0_0_15px_rgba(0,240,255,0.1)] overflow-hidden backdrop-blur-sm text-sm sm:text-base font-mono"
>
	<div class="p-6 border-b border-[#2dd4bf]/20">
		<div class="profile-header">
			<Image
				src={avatarImage}
				data-lang-ja={translations.ja["avatar.alt"]}
				data-lang-en={translations.en["avatar.alt"]}
				alt={translations.ja["avatar.alt"]}
				class="profile-avatar"
				width={80}
				height={80}
				loading="eager"
			/>
			<div>
				<div class="flex items-center gap-3">
					<p class="profile-name" style="margin-bottom: 0;">HappyOnigiri</p>
					<div class="flex items-center gap-2">
						<a
							href="https://x.com/H_OnigiriWorks"
							target="_blank"
							rel="noopener noreferrer"
							class="text-[#94a3b8] hover:text-[#00f0ff] transition-colors"
							title="X (Twitter)"
							aria-label="X (Twitter)"
						>
							<svg
								class="w-4 h-4"
								fill="currentColor"
								viewBox="0 0 24 24"
								aria-hidden="true"
								><path
									d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 22.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
								></path></svg
							>
						</a>
						<a
							href="https://github.com/HappyOnigiri"
							target="_blank"
							rel="noopener noreferrer"
							class="text-[#94a3b8] hover:text-[#e2e8f0] transition-colors"
							title="GitHub"
							aria-label="GitHub"
						>
							<svg
								class="w-4.5 h-4.5"
								fill="currentColor"
								viewBox="0 0 24 24"
								aria-hidden="true"
								><path
									fill-rule="evenodd"
									d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
									clip-rule="evenodd"></path></svg
							>
						</a>
						<a
							href="https://zenn.dev/happy_onigiri"
							target="_blank"
							rel="noopener noreferrer"
							class="text-[#94a3b8] hover:text-[#3EA8FF] transition-colors"
							title="Zenn"
							aria-label="Zenn"
						>
							<svg
								class="w-4 h-4 ml-0.5"
								fill="currentColor"
								viewBox="0 0 88.3 88.3"
								aria-hidden="true"
								><path
									d="M3.9,83.3h17c0.9,0,1.7-0.5,2.2-1.2L69.9,5.2c0.6-1-0.1-2.2-1.3-2.2H52.5c-0.8,0-1.5,0.4-1.9,1.1L3.1,81.9C2.8,82.5,3.2,83.3,3.9,83.3z"
								></path><path
									d="M62.5,82.1l22.1-35.5c0.7-1.1-0.1-2.5-1.4-2.5h-16c-0.6,0-1.2,0.3-1.5,0.8L43,81.2c-0.6,0.9,0.1,2.1,1.2,2.1h16.3C61.3,83.3,62.1,82.9,62.5,82.1z"
								></path></svg
							>
						</a>
					</div>
				</div>
				<p class="profile-bio" data-i18n="bio" data-i18n-html>
					思いつきでドリブン開発をしています。<br />
					ジャンルは問わず「面白そう」「あったら便利そう」と思ったものを形にしています。<br
					/>
					感想・質問・雑談など <a
						href="https://x.com/H_OnigiriWorks"
						class="profile-link"
						target="_blank"
						rel="noopener noreferrer">X</a
					> でお気軽にどうぞ！
				</p>
			</div>
		</div>
	</div>

	<div class="px-6 pt-5 pb-1 flex items-baseline justify-between">
		<h2 class="section-heading" style="margin-bottom: 0;">
			Development Status
		</h2>
		<span class="text-xs text-[#94a3b8] font-mono"
			>Last Updated: {lastSync}</span
		>
	</div>

	<div class="p-6 overflow-x-auto">
		<div class="flex flex-wrap gap-4 text-[#e2e8f0]">
			<div
				class="flex-1 min-w-[140px] bg-gradient-to-br from-[#141623] to-[#1a1d2d] border border-[#2dd4bf]/20 p-4 rounded-xl shadow-lg relative overflow-hidden group"
			>
				<div
					class="absolute -right-4 -top-4 w-12 h-12 bg-[#00f0ff]/10 rounded-full blur-xl group-hover:bg-[#00f0ff]/20 transition-all"
				>
				</div>
				<div class="text-[#94a3b8] text-xs font-semibold tracking-wider mb-2">
					Changed Lines
				</div>
				<div class="text-2xl font-bold font-mono text-[#00f0ff]">
					{formatNumber(statusData.addedLines + statusData.deletedLines)}
				</div>
			</div>

			<div
				class="flex-1 min-w-[140px] bg-gradient-to-br from-[#141623] to-[#1a1d2d] border border-[#2dd4bf]/20 p-4 rounded-xl shadow-lg relative overflow-hidden group"
			>
				<div
					class="absolute -right-4 -top-4 w-12 h-12 bg-[#ea580c]/10 rounded-full blur-xl group-hover:bg-[#ea580c]/20 transition-all"
				>
				</div>
				<div class="text-[#94a3b8] text-xs font-semibold tracking-wider mb-2">
					Commits
				</div>
				<div class="text-2xl font-bold font-mono text-[#ea580c]">
					{formatNumber(statusData.commits)}
				</div>
			</div>

			<div
				class="flex-1 min-w-[140px] bg-gradient-to-br from-[#141623] to-[#1a1d2d] border border-[#2dd4bf]/20 p-4 rounded-xl shadow-lg relative overflow-hidden group"
			>
				<div
					class="absolute -right-4 -top-4 w-12 h-12 bg-[#b534ff]/10 rounded-full blur-xl group-hover:bg-[#b534ff]/20 transition-all"
				>
				</div>
				<div class="text-[#94a3b8] text-xs font-semibold tracking-wider mb-2">
					Merged PRs
				</div>
				<div class="text-2xl font-bold font-mono text-[#b534ff]">
					{formatNumber(statusData.mergedPRs)}
				</div>
			</div>

			<div
				class="flex-1 min-w-[140px] bg-gradient-to-br from-[#141623] to-[#1a1d2d] border border-[#2dd4bf]/20 p-4 rounded-xl shadow-lg relative overflow-hidden group"
			>
				<div
					class="absolute -right-4 -top-4 w-12 h-12 bg-[#10b981]/10 rounded-full blur-xl group-hover:bg-[#10b981]/20 transition-all"
				>
				</div>
				<div class="text-[#94a3b8] text-xs font-semibold tracking-wider mb-2">
					CI Runs
				</div>
				<div class="text-2xl font-bold font-mono text-[#10b981]">
					{formatNumber(statusData.ciRuns)}
				</div>
			</div>

			{
				((statusData as { ossPRs?: number }).ossPRs ?? 0) > 0 && (
					<div class="flex-1 min-w-[140px] bg-gradient-to-br from-[#141623] to-[#1a1d2d] border border-[#2dd4bf]/20 p-4 rounded-xl shadow-lg relative overflow-hidden group">
						<div class="absolute -right-4 -top-4 w-12 h-12 bg-[#f59e0b]/10 rounded-full blur-xl group-hover:bg-[#f59e0b]/20 transition-all" />
						<div class="text-[#94a3b8] text-xs font-semibold tracking-wider mb-2">
							OSS PRs
						</div>
						<div class="text-2xl font-bold font-mono text-[#f59e0b]">
							{formatNumber((statusData as { ossPRs?: number }).ossPRs!)}
						</div>
					</div>
				)
			}
		</div>

		<div class="mt-4 bg-[#141623]/50 border border-[#2dd4bf]/10 rounded-xl p-4">
			<div class="flex items-center gap-4 mb-3">
				<div
					class="text-[#94a3b8] text-xs font-semibold tracking-wider whitespace-nowrap"
				>
					Languages
				</div>
				<div class="flex-1 flex h-2 rounded-full overflow-hidden bg-[#000]">
					{
						statusData.languages.map((lang) => (
							<div
								style={`width: ${lang.value}%; background-color: ${lang.color};`}
								title={`${lang.label} ${lang.value}%`}
								class="h-full"
							/>
						))
					}
				</div>
			</div>
			<div class="flex flex-wrap gap-x-4 gap-y-2 mt-2">
				{
					statusData.languages.map((lang) => (
						<div class="flex items-center text-xs">
							<span
								class="w-2.5 h-2.5 rounded-full mr-2"
								style={`background-color: ${lang.color};`}
							/>
							<span class="text-[#94a3b8] mr-1.5">{lang.label}</span>
							<span class="font-bold text-[#e2e8f0]">{lang.value}%</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</div>
