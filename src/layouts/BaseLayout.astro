---
import "../styles/global.css";
import "../styles/portal.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "個人活動ポートフォリオ" } = Astro.props as Props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<div class="cyber-scanlines" aria-hidden="true"></div>
		<div class="cyber-container">
			<div class="cyber-header-top" aria-hidden="true"></div>

			<main id="main-content" class="portal-main">
				<slot />
			</main>

			<footer class="cyber-footer">
				<div class="footer-content">
					<div class="footer-info">
						<p class="copyright">
							&copy; {currentYear} HappyOnigiri. All rights reserved.
						</p>
						<div class="footer-links">
							<a
								href="https://x.com/H_OnigiriWorks"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="X（Twitter）で HappyOnigiri をフォロー"
								class="social-link x-link"
							>
								<img
									src="/images/logos/logo_x.svg"
									alt=""
									aria-hidden="true"
									width="18"
									height="18"
								/>
							</a>
							<a
								href="https://github.com/HappyOnigiri/Portal"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="GitHub でプロジェクトを見る"
								class="social-link github-link"
							>
								<img
									src="/images/logos/logo_github.svg"
									alt=""
									aria-hidden="true"
									width="20"
									height="20"
								/>
							</a>
						</div>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
