---
import "../styles/global.css";
import "../styles/portal.css";
import { version } from "../../package.json";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import { translations } from "../utils/translations";

interface Props {
	title: string;
	description?: string;
	/** canonical の pathname（先頭スラッシュ付き）。省略時は `Astro.url.pathname` */
	canonicalPath?: string;
	robots?: string;
	ogType?: string;
	jsonLd?: Record<string, unknown>;
	theme?: "cyber" | "pop" | "terminal" | "brutal" | "nagomi";
}

const {
	title,
	description = "個人活動ポートフォリオ",
	canonicalPath,
	robots = "index, follow",
	ogType = "website",
	jsonLd,
	theme = "cyber",
} = Astro.props;

const currentYear = new Date().getFullYear();
const site = Astro.site;
const pathForCanonical = canonicalPath ?? Astro.url.pathname;
/** ルートはサイトマップ（@astrojs/sitemap）と同じくオリジン直下（末尾スラッシュなし）に揃える */
const canonicalHref =
	pathForCanonical === "/" && site
		? site.origin
		: new URL(pathForCanonical, site ?? Astro.url).href;
const socialImageHref = new URL("/images/avatar.jpg", site ?? Astro.url).href;
const jsonLdSerialized = jsonLd ? JSON.stringify(jsonLd) : null;
---

<!doctype html>
<html lang="ja" data-theme={theme}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<link rel="canonical" href={canonicalHref} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:image" content={socialImageHref} />
		<meta property="og:image:alt" content="HappyOnigiri avatar" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageHref} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		{
			jsonLdSerialized && (
				<script type="application/ld+json" set:html={jsonLdSerialized} />
			)
		}
		{/* FOUC 対策: JS 実行前に lang と theme を設定 */}
	</head>
	<body>
		<div class="portal-container">
			<div class="floating-ui-pill" id="floating-ui-pill">
				<div class="floating-ui-content">
					<div class="lang-switcher" style="margin-top: 0; opacity: 1;">
						<button data-lang-btn="en" class="lang-btn">EN</button>
						<span class="lang-divider">|</span>
						<button data-lang-btn="ja" class="lang-btn">JP</button>
					</div>
					<ThemeSwitcher theme={theme} />
				</div>
				<button
					id="mobile-menu-toggle"
					class="mobile-menu-btn"
					aria-label="Toggle Menu"
					aria-expanded="false"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="icon-menu"
						><line x1="3" y1="12" x2="21" y2="12"></line><line
							x1="3"
							y1="6"
							x2="21"
							y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
					>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="icon-close"
						><line x1="18" y1="6" x2="6" y2="18"></line><line
							x1="6"
							y1="6"
							x2="18"
							y2="18"></line></svg
					>
				</button>
			</div>

			<main id="main-content" class="portal-main">
				<slot />
			</main>

			<footer class="portal-footer">
				<div class="footer-content">
					<div class="footer-info">
						<p class="copyright">
							&copy; {currentYear} HappyOnigiri. All rights reserved.
						</p>
						<a
							href="https://github.com/HappyOnigiri/Portal"
							target="_blank"
							rel="noopener noreferrer"
							class="portal-version"
						>
							Portal v{version}
						</a>
						<div class="footer-links">
							<a
								href="https://x.com/H_OnigiriWorks"
								target="_blank"
								rel="noopener noreferrer"
								data-i18n-attr="aria-label:footer.x.aria"
								aria-label="X（Twitter）で HappyOnigiri をフォロー"
								class="social-link x-link"
							>
								<img
									src="/images/logos/logo_x.svg"
									alt=""
									aria-hidden="true"
									width="18"
									height="18"
								/>
							</a>
							<a
								href="https://github.com/HappyOnigiri"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="GitHub"
								class="social-link github-link"
							>
								<img
									src="/images/logos/logo_github.svg"
									alt=""
									aria-hidden="true"
									width="20"
									height="20"
								/>
							</a>
						</div>
					</div>
				</div>
			</footer>
		</div>

		<script is:inline define:vars={{ translations }}>
			window.__portalI18nResources = translations;
		</script>
		<script>
			import { inject } from "@vercel/analytics";
			inject();
		</script>
		<script>
			import { initI18n } from "../utils/i18n";
			initI18n();

			const pill = document.getElementById("floating-ui-pill");
			const btn = document.getElementById("mobile-menu-toggle");
			if (btn && pill) {
				// テーマ切替直後はアニメーションなしでメニューを展開した状態にする
				if (sessionStorage.getItem("expandPillOnLoad") === "1") {
					sessionStorage.removeItem("expandPillOnLoad");
					pill.classList.add("no-animate", "expanded");
					btn.setAttribute("aria-expanded", "true");
				}

				btn.addEventListener("click", (e) => {
					e.stopPropagation();
					pill.classList.remove("no-animate");
					const isExpanded = pill.classList.toggle("expanded");
					btn.setAttribute("aria-expanded", isExpanded.toString());
				});
				document.addEventListener("click", (e) => {
					if (!pill.contains(e.target as Node)) {
						pill.classList.remove("expanded");
						btn.setAttribute("aria-expanded", "false");
					}
				});
			}
		</script>
	</body>
</html>
