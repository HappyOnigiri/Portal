---
import "../styles/portal.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "個人活動ポートフォリオ" } = Astro.props as Props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<div class="cyber-scanlines" aria-hidden="true"></div>
		<div class="site-shell">
			<header class="portal-header">
				<a class="portal-brand" href="/">PORTAL://ACTIVITIES</a>
				<nav aria-label="グローバルナビゲーション">
					<ul class="portal-nav">
						<li><a href="/">Top</a></li>
						<li><a href="/about">About</a></li>
					</ul>
				</nav>
			</header>

			<main id="main-content" class="portal-main">
				<slot />
			</main>

			<footer class="portal-footer">
				<p>© {new Date().getFullYear()} Cyber Portfolio</p>
			</footer>
		</div>
	</body>
</html>
