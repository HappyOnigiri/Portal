---
import { getCollection } from "astro:content";
import { SITE_ORIGIN } from "../../constants/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Project } from "../../utils/project";
import {
	breadcrumbList,
	buildJsonLdGraph,
	personHappyOnigiri,
	softwareApplicationProject,
} from "../../utils/structured-data";
import { translations } from "../../utils/translations";

interface Props {
	project: Project;
	projectId: string;
}

export async function getStaticPaths() {
	const entries = await getCollection("projects");
	return entries.map((entry) => ({
		params: { id: entry.id },
		props: { project: entry.data, projectId: entry.id },
	}));
}

const { project, projectId } = Astro.props as Props;
const detailPath = `/projects/${projectId}`;

const jsonLd = buildJsonLdGraph([
	personHappyOnigiri(SITE_ORIGIN),
	softwareApplicationProject(SITE_ORIGIN, project, detailPath),
	breadcrumbList(SITE_ORIGIN, [
		{ name: "トップ", path: "/" },
		{ name: "プロジェクト一覧", path: "/projects" },
		{ name: project.title, path: detailPath },
	]),
]);
---

<BaseLayout
	title={`${project.title} | ONIGIRI PORTAL`}
	description={project.description}
	canonicalPath={detailPath}
	jsonLd={jsonLd}
>
	<nav class="breadcrumb" aria-label="パンくず">
		<a href="/">トップ</a>
		<span class="breadcrumb-sep" aria-hidden="true">/</span>
		<a href="/projects">プロジェクト</a>
		<span class="breadcrumb-sep" aria-hidden="true">/</span>
		<span class="breadcrumb-current">{project.title}</span>
	</nav>

	<article class="project-detail">
		<header class="project-detail-header">
			<h1
				class="project-detail-title"
				data-lang-ja={project.title}
				data-lang-en={project.title_en || project.title}
			>
				{project.title}
			</h1>
			{
				project.category && (
					<span class="card-category" data-color={project.category_color}>
						{project.category}
					</span>
				)
			}
		</header>

		{
			project.image && (
				<div class="project-detail-image">
					<img
						src={project.image}
						data-lang-ja={`${project.title} のサムネイル`}
						data-lang-en={`${project.title_en || project.title} thumbnail`}
						alt={`${project.title} のサムネイル`}
						loading="eager"
					/>
				</div>
			)
		}

		<p
			class="project-detail-body"
			data-lang-ja={project.description}
			data-lang-en={project.description_en || project.description}
		>
			{project.description}
		</p>

		<p class="external-notice" data-i18n="project.externalHint">
			{translations.ja["project.externalHint"]}
		</p>

		<div class="project-detail-actions">
			{
				project.url && (
					<a
						class="btn-external"
						href={project.url}
						target="_blank"
						rel="noopener noreferrer"
						data-i18n="project.externalCta"
					>
						{translations.ja["project.externalCta"]}
					</a>
				)
			}
			<a class="btn-back" href="/projects" data-i18n="project.back">
				{translations.ja["project.back"]}
			</a>
		</div>
	</article>
</BaseLayout>
