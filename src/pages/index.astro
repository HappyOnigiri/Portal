---
import { getCollection } from "astro:content";
import AuthorStatusWidget from "../components/AuthorStatusWidget.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ZennArticlesWidget from "../components/ZennArticlesWidget.astro";
import { SITE_ORIGIN } from "../constants/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortProjectsByOrder } from "../utils/project";
import {
	buildJsonLdGraph,
	itemListProjects,
	personHappyOnigiri,
	webSiteRoot,
} from "../utils/structured-data";
import { translations } from "../utils/translations";

const metaDescriptionJa = translations.ja["meta.description"];

const projectEntries = await getCollection("projects");
const projects = sortProjectsByOrder(projectEntries.map((entry) => entry.data));
const zennEntries = (await getCollection("zennArticles"))
	.sort(
		(a, b) =>
			new Date(b.data.published_at).getTime() -
			new Date(a.data.published_at).getTime(),
	)
	.slice(0, 3);

const jsonLd = buildJsonLdGraph([
	personHappyOnigiri(SITE_ORIGIN),
	webSiteRoot(SITE_ORIGIN, metaDescriptionJa),
	itemListProjects(
		SITE_ORIGIN,
		projects.map((p) => ({
			id: p.id,
			title: p.title,
			description: p.description,
		})),
	),
]);
---

<BaseLayout
	title="ONIGIRI PORTAL | トップ"
	description={metaDescriptionJa}
	canonicalPath="/"
	jsonLd={jsonLd}
>
	<section class="cyber-header">
		<h1 class="cyber-glitch">ONIGIRI PORTAL</h1>
	</section>

	<section id="projects" aria-label="Projects" style="margin-bottom: 3rem;">
		<div class="grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	{
		zennEntries.length > 0 && (
			<section
				id="articles"
				aria-label="Zenn Articles"
				style="margin-bottom: 3rem;"
			>
				<ZennArticlesWidget articles={zennEntries} />
			</section>
		)
	}

	<section
		id="status"
		aria-label="HappyOnigiri Status"
		style="margin-bottom: 3rem;"
	>
		<AuthorStatusWidget />
	</section>
</BaseLayout>
